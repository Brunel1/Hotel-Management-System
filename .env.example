# Variables d'environnement pour le projet Gestion-Hôtel
# Copiez ce fichier en .env et remplissez les valeurs réelles

# Base de données Prisma
DATABASE_URL="file:./dev.db"

# Clé secrète pour JWT (à remplacer par une clé forte en production)
JWT_SECRET="your-secret-key-here"

# Clé API Google Maps (optionnelle)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Configuration de l'application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Gestion-Hôtel"

# Configuration email (optionnelle)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-email-password"
SMTP_FROM="noreply@hotel.mg"

# Configuration de paiement (optionnelle)
STRIPE_PUBLIC_KEY="your-stripe-public-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"
